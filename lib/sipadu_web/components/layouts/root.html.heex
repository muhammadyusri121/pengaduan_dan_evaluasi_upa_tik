<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · Sistem Pengaduan Terpadu UPA TIK">
      {assigns[:page_title] || "Sipadu"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="bg-[#F8FAFC] min-h-screen font-sans text-slate-800 relative selection:bg-blue-200 selection:text-blue-900 flex flex-col">
    <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-300/20 rounded-full blur-[100px]">
      </div>
      <div class="absolute top-40 -left-20 w-72 h-72 bg-indigo-300/20 rounded-full blur-[80px]">
      </div>
    </div>

    <header class="sticky top-0 z-50 bg-white/75 backdrop-blur-xl border-b border-slate-200/60 shadow-sm transition-all duration-300 supports-[backdrop-filter]:bg-white/60">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 md:h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 cursor-pointer group">
          <div class="bg-gradient-to-tr from-blue-600 to-indigo-500 text-white p-1.5 rounded-xl flex items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-105 transition-all duration-300">
            <.icon name="hero-question-mark-circle" class="w-6 h-6" />
          </div>
          <span class="font-extrabold text-xl md:text-2xl bg-clip-text text-transparent bg-gradient-to-r from-slate-900 to-slate-700 tracking-tight">
            SIPADU
          </span>
        </a>

        <div class="flex items-center gap-4 md:gap-8">
          <a href="#" class="hidden sm:block text-sm font-semibold text-slate-600 hover:text-blue-600 transition-colors duration-300">
            Bantuan
          </a>
          
          <%= if assigns[:current_user] do %>
            <div class="dropdown dropdown-end">
              <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar border border-slate-200 hover:shadow-md transition-all">
                <div class="w-10 rounded-full">
                  <% image_url = if is_nil(@current_user.image) or @current_user.image == "", do: "https://ui-avatars.com/api/?name=#{URI.encode(@current_user.name || "User")}&background=random", else: @current_user.image %>
                  <img alt="User Avatar" src={image_url} referrerpolicy="no-referrer" />
                </div>
              </div>
              <ul tabindex="0" class="mt-3 z-[1] p-2 shadow menu menu-sm dropdown-content bg-white rounded-box w-52 border border-slate-100">
                <li class="menu-title px-4 py-2 opacity-100">
                  <div class="font-bold text-slate-800">{@current_user.name}</div>
                  <div class="text-xs text-slate-500">{@current_user.email}</div>
                </li>
                <div class="divider my-0"></div>
                <li><a href="/survei" class="py-3 font-semibold text-slate-700"><.icon name="hero-document-text" class="w-4 h-4 mr-2" /> Survei Evaluasi</a></li>
                <li><a href="/laporan" class="py-3 font-semibold text-slate-700"><.icon name="hero-chat-bubble-bottom-center-text" class="w-4 h-4 mr-2" /> Laporan Pengaduan</a></li>
                <li><a href="/auth/signout" class="text-red-600 py-3 font-semibold"><.icon name="hero-arrow-right-on-rectangle" class="w-4 h-4 mr-2" /> Logout</a></li>
              </ul>
            </div>
          <% else %>
            <.link
              href={~p"/login"}
              class="bg-slate-900 text-white text-sm font-semibold px-5 md:px-7 py-2 md:py-2.5 rounded-full hover:bg-blue-600 hover:shadow-[0_8px_20px_rgb(37,99,235,0.25)] hover:-translate-y-0.5 active:scale-95 transition-all duration-300"
            >
              Masuk
            </.link>
          <% end %>
        </div>
      </div>
    </header>

    {@inner_content}

    <footer class="bg-slate-900 py-8 md:py-10 text-center border-t border-slate-800 mt-auto">
      <div class="flex items-center justify-center gap-2 mb-3">
        <.icon name="hero-question-mark-circle" class="w-5 h-5 text-slate-500" />
        <span class="font-bold text-lg text-slate-300 tracking-tight">SIPADU</span>
      </div>
      <p class="text-xs md:text-sm text-slate-400 px-4">
        &copy; 2026 Sistem Pengaduan dan Evaluasi Terpadu UPA TIK.
      </p>
    </footer>
  </body>
</html>
