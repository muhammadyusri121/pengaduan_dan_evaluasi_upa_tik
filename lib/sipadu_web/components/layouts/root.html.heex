<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · Sistem Pengaduan Terpadu UPA TIK">
      {assigns[:page_title] || "Sipadu"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));

        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>

  <body class="bg-[#F8FAFC] min-h-screen font-sans text-slate-800 relative selection:bg-blue-200 selection:text-blue-900 flex flex-col">
    <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10 flex items-center justify-center">
      <div class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] bg-blue-400/20 rounded-full blur-[120px]">
      </div>
      <div class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] bg-indigo-400/20 rounded-full blur-[120px]">
      </div>
    </div>

    <header class="sticky top-0 z-50 bg-white/75 backdrop-blur-xl border-b border-slate-200/60 shadow-sm transition-all duration-300 supports-[backdrop-filter]:bg-white/60">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 md:h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 cursor-pointer group">
          <div class="bg-gradient-to-tr from-blue-600 to-indigo-500 text-white p-1.5 rounded-xl flex items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-105 transition-all duration-300">
            <.icon name="hero-question-mark-circle" class="w-6 h-6" />
          </div>
          <span class="font-extrabold text-xl md:text-2xl bg-clip-text text-transparent bg-gradient-to-r from-slate-900 to-slate-700 tracking-tight">
            SIPADU
          </span>
        </a>

        <div class="flex items-center gap-4 md:gap-8">
          <a
            href="#"
            class="hidden sm:block text-sm font-semibold text-slate-600 hover:text-blue-600 transition-colors duration-300"
          >
            Bantuan
          </a>

          <%= if assigns[:current_user] do %>
            <div class="relative group">
              <div class="w-10 h-10 rounded-full bg-white border border-slate-200 shadow-sm cursor-pointer transition-all duration-300 group-hover:shadow-md overflow-hidden flex items-center justify-center ring-2 ring-transparent group-hover:ring-blue-100">
                <% image_url =
                  if is_nil(@current_user.image) or @current_user.image == "",
                    do:
                      "https://ui-avatars.com/api/?name=#{URI.encode(@current_user.name || "User")}&background=random",
                    else: @current_user.image %>
                <img
                  alt="User Avatar"
                  src={image_url}
                  referrerpolicy="no-referrer"
                  class="w-full h-full object-cover"
                />
              </div>

              <div class="absolute right-0 mt-2 w-64 bg-white rounded-2xl shadow-[0_10px_40px_rgb(0,0,0,0.1)] border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top-right group-hover:scale-100 scale-95 z-50 overflow-hidden">
                <div class="px-5 py-4 border-b border-slate-100 bg-slate-50/50">
                  <p class="text-sm font-extrabold text-slate-800 truncate">
                    {@current_user.name}
                  </p>
                  <p class="text-[13px] text-slate-500 truncate mt-0.5">{@current_user.email}</p>
                </div>

                <div class="py-2">
                  <.link
                    href={~p"/survei"}
                    class="flex items-center gap-3 px-5 py-2.5 text-sm font-medium text-slate-600 hover:text-blue-600 hover:bg-blue-50 transition-colors"
                  >
                    <.icon
                      name="hero-document-text"
                      class="w-4 h-4 text-slate-400 group-hover:text-blue-600"
                    /> Survei Evaluasi
                  </.link>
                  <.link
                    href={~p"/laporan"}
                    class="flex items-center gap-3 px-5 py-2.5 text-sm font-medium text-slate-600 hover:text-blue-600 hover:bg-blue-50 transition-colors"
                  >
                    <.icon
                      name="hero-chat-bubble-left-ellipsis"
                      class="w-4 h-4 text-slate-400 group-hover:text-blue-600"
                    /> Laporan Pengaduan
                  </.link>
                </div>

                <div class="border-t border-slate-100 py-1.5 bg-red-50/30">
                  <.link
                    href={~p"/auth/signout"}
                    class="flex items-center gap-3 px-5 py-2.5 text-sm font-bold text-red-600 hover:text-red-700 hover:bg-red-100/50 transition-colors"
                  >
                    <.icon name="hero-arrow-right-on-rectangle" class="w-4 h-4" /> Logout
                  </.link>
                </div>
              </div>
            </div>
          <% else %>
            <.link
              href={~p"/login"}
              class="bg-slate-900 text-white text-sm font-semibold px-5 md:px-7 py-2 md:py-2.5 rounded-full hover:bg-blue-600 hover:shadow-[0_8px_20px_rgb(37,99,235,0.25)] hover:-translate-y-0.5 active:scale-95 transition-all duration-300"
            >
              Masuk
            </.link>
          <% end %>
        </div>
      </div>
    </header>

    <div class="flex-grow">
      <div class="fixed top-24 right-4 sm:top-28 sm:right-6 z-[60] flex flex-col gap-3">
        <.flash kind={:info} title="Informasi" flash={@flash} />
        <.flash kind={:error} title="Gagal!" flash={@flash} />
      </div>

      {@inner_content}
    </div>

    <footer class="bg-slate-900 py-8 md:py-10 text-center border-t border-slate-800 mt-auto">
      <div class="flex items-center justify-center gap-2 mb-3">
        <.icon name="hero-question-mark-circle" class="w-5 h-5 text-slate-500" />
        <span class="font-bold text-lg text-slate-300 tracking-tight">SIPADU</span>
      </div>
      <p class="text-xs md:text-sm text-slate-400 px-4">
        &copy; 2026 Sistem Pengaduan dan Evaluasi Terpadu UPA TIK.
      </p>
    </footer>
  </body>
</html>
